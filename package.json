{
  "name": "@emitwave/emitwavejs",
  "version": "0.1.3",
  "description": "Official EmitWave JavaScript/TypeScript SDK for realtime",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "centrifuge": "^5.3.3"
  },
  "devDependencies": {
    "centrifuge": "^5.3.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emitwave/emitwave-js"
  },
  "keywords": [
    "emitwave",
    "realtime",
    "websocket",
    "pubsub",
    "presence"
  ]
}
